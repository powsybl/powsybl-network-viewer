{
    "name": "@powsybl/sankey",
    "version": "3.6.0-dev.0",
    "description": "Sankey diagram renderer for power-flow data.",
    "author": "PowSyBl team",
    "homepage": "https://www.powsybl.org/",
    "license": "MPL-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/powsybl/powsybl-network-viewer.git"
    },
    "type": "module",
    "main": "./dist/powsybl-sankey.cjs",
    "module": "./dist/powsybl-sankey.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/powsybl-sankey.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/powsybl-sankey.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "files": ["dist"],
    "scripts": {
        "build": "vite build",
        "test": "vitest run",
        "check": "tsc --noEmit",
        "check:pack": "attw --pack",
        "lint": "eslint --cache --report-unused-disable-directives --report-unused-inline-configs warn --max-warnings 0 .",
        "lint:fix": "eslint --cache --report-unused-disable-directives --report-unused-inline-configs warn --fix .",
        "lint:format": "prettier --cache --check --ignore-path ../../.gitignore .",
        "lint:format:fix": "prettier --cache --write --ignore-path ../../.gitignore .",
        "demo": "vite demo/ --config demo/vite.config.ts"
    },
    "peerDependencies": {},
    "dependencies": {
        "@svgdotjs/svg.js": "^3.2.4",
        "@svgdotjs/svg.panzoom.js": "^2.1.2"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.17.4",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.31.0",
        "vite": "^7.2.4",
        "vite-plugin-checker": "^0.12.0",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.0.18"
    }
}
