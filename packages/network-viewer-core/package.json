{
    "name": "@powsybl/network-viewer-core",
    "version": "3.4.0-dev.0",
    "description": "Core TypeScript library for PowSyBl network viewers (NAD/SLD)",
    "author": "PowSyBl team",
    "homepage": "https://www.powsybl.org/",
    "license": "MPL-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/powsybl/powsybl-network-viewer.git"
    },
    "type": "module",
    "main": "./dist/powsybl-network-viewer-core.cjs",
    "module": "./dist/powsybl-network-viewer-core.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/powsybl-network-viewer-core.js"
            },
            "require": {
                "types": "./dist/index.d.cts",
                "default": "./dist/powsybl-network-viewer-core.cjs"
            }
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "vite build",
        "check": "tsc --noEmit",
        "check:pack": "attw --pack",
        "lint": "eslint --cache --report-unused-disable-directives --report-unused-inline-configs warn --max-warnings 0 .",
        "lint:fix": "eslint --cache --report-unused-disable-directives --report-unused-inline-configs warn --fix .",
        "lint:format": "prettier --cache --check --ignore-path ../../.gitignore .",
        "lint:format:fix": "prettier --cache --write --ignore-path ../../.gitignore ."
    },
    "dependencies": {
        "lodash.debounce": "^4.0.8",
        "@svgdotjs/svg.js": "^3.2.4",
        "@svgdotjs/svg.panzoom.js": "^2.1.2"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.17.4",
        "@types/lodash.debounce": "^4.0.9",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.31.0",
        "vite": "^7.2.4",
        "vite-plugin-checker": "^0.9.1",
        "vite-plugin-dts": "^4.5.4"
    }
}
